# Obligatorio para conectar Supabase Auth desde cliente y servidor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Obligatorio para migraciones, consultas Drizzle y seed.
DATABASE_URL=

# Obligatorio solo para tareas administrativas: seed de usuarios, storage privado y acciones de servicio.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional en desarrollo. Si falta, los emails se registran como pendientes y no se envian.
RESEND_API_KEY=
EMAIL_FROM="Controla <notificaciones@controla.local>"

# Opcional hasta activar Trigger.dev en un entorno real.
TRIGGER_SECRET_KEY=

# Opcional hasta activar pagos reales.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Opcional para captura de errores.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Recomendado para emails, enlaces firmados y despliegue.
NEXT_PUBLIC_APP_URL=http://localhost:3000
