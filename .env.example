# Controla environment template.
# Never commit real secrets. Copy this file to .env.local for local development.

# Required for Supabase Auth in browser and server components.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alternative name used by newer Supabase dashboards. The app accepts either this or NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required for Drizzle queries, migrations and seed. Server only.
DATABASE_URL=

# Local fallback for development when DATABASE_URL/Supabase are missing.
# auto = writable local demo store, disabled = fail closed when real services are missing.
CONTROLLA_DEMO_MODE=auto

# Required only for privileged server operations: Supabase Admin Auth and private Storage.
# Server only. Never expose this as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Public application URL used in emails, callbacks and deploy previews.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional email delivery. If missing, reminder email delivery is skipped safely.
RESEND_API_KEY=
EMAIL_FROM="Controla <notificaciones@controla.local>"

# Optional scheduled jobs. If missing, scheduled tasks stay inactive.
TRIGGER_SECRET_KEY=

# Optional billing. If missing, billing pages stay in preparation mode and webhooks fail closed.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional error reporting. Do not include personal data or secrets in Sentry context.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
